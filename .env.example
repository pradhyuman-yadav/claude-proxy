# ── Required ──────────────────────────────────────────────────────────────────
# Your Claude Code OAuth token.
# 1. Install Claude Code:  npm install -g @anthropic-ai/claude-code
# 2. Authenticate:         claude auth login
# 3. Copy token from:      ~/.claude/credentials.json  (Linux/Mac)
#                          %APPDATA%\Claude\credentials.json  (Windows)
# Token looks like:        sk-ant-oat01-...
CLAUDE_CODE_OAUTH_TOKEN=

# ── Gemini backend (optional) ─────────────────────────────────────────────────
# Enable Gemini models via Google's OFFICIAL OpenAI-compatible endpoint.
# Get a key at https://aistudio.google.com/apikey (free tier available).
# NOTE: this is deliberately NOT a Gemini-CLI OAuth proxy — Google suspends
# accounts that pipe CLI OAuth tokens through third-party proxies.
GEMINI_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Optional. Set to protect /v1/* and the dashboard with Bearer token auth.
# Leave empty to allow open access (useful on a private network).
# Generate one: openssl rand -hex 32
API_KEY=

# ── Port configuration ────────────────────────────────────────────────────────
# HOST_PORT: port exposed on the host machine (what clients connect to)
# PORT:      port inside the container (usually same as HOST_PORT)
HOST_PORT=3456
PORT=3456
